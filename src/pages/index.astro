---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
---

<BaseLayout>
  <main class="site-shell">
    <section class="hero" aria-labelledby="hero-heading">
      <div>
        <p class="hero__eyebrow">{site.title}</p>
        <h1 id="hero-heading">{site.hero.heading}</h1>
        {site.hero.subheading && <p class="hero__subheading">{site.hero.subheading}</p>}
        {site.cta && <a class="button" href={site.cta.href}>{site.cta.label}</a>}
      </div>
      {
        site.hero.image && (
          <div class="hero__media">
            <img src={site.hero.image} alt="" loading="eager" />
          </div>
        )
      }
    </section>

    {
      site.bio && (
        <section class="section" aria-labelledby="bio-heading">
          <h2 id="bio-heading">{site.bio.heading ?? site.title}</h2>
          <p>{site.bio.body}</p>
          {site.bio.image && <img src={site.bio.image} alt="" loading="lazy" />}
        </section>
      )
    }

    {
      site.links && site.links.length > 0 && (
        <section class="section" aria-labelledby="links-heading">
          <h2 id="links-heading">Links</h2>
          <ul class="link-list">
            {site.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</BaseLayout>
